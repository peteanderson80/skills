# Ignore everything in this Codex home by default.
*

# Keep the repository metadata and the skill library under version control.
!.gitignore
!skills/
!skills/**
!README.md

# Still ignore generated Python artifacts inside tracked skill directories.
__pycache__/
*.py[cod]

# Ignore installed Node dependencies inside tracked skill directories.
/skills/node_modules/
/skills/**/node_modules/